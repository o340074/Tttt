# AdVault — environment template (docs/17 §1). Copy to `.env`, fill real values,
# and keep `.env` out of git (it is .gitignored). In production `validateEnv`
# refuses to boot if any secret still contains a "change-me"/dev default.
#
# Generate strong secrets, e.g.:
#   openssl rand -hex 32                      # JWT / webhook secrets
#   printf 'v1:%s' "$(openssl rand -base64 32)"   # PAYLOAD_ENCRYPTION_KEY

# --- Runtime ---
NODE_ENV=production
PORT=3000

# --- Datastores ---
# Use TLS in transit; disk encryption at the provider level.
DATABASE_URL=postgresql://advault:CHANGE_ME@postgres:5432/advault?schema=public
# Sessions/jti, stock reservation, BullMQ notifications queue.
REDIS_URL=redis://redis:6379

# --- Compose infra (only when running Postgres/Redis via docker-compose.prod.yml;
#     drop these and point DATABASE_URL at your managed DB in real prod).
#     POSTGRES_* must match the credentials embedded in DATABASE_URL above.
POSTGRES_USER=advault
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=advault

# --- Web origin / links ---
# Only the trusted frontend origin(s), comma-separated. Never "*".
CORS_ORIGIN=https://advault.example.com
# Base URL used to build links in transactional emails.
WEB_URL=https://advault.example.com

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=CHANGE_ME_32_bytes_hex
JWT_REFRESH_SECRET=CHANGE_ME_32_bytes_hex
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Payments ---
# HMAC-SHA256 secret the acquirer signs webhooks with.
PAYMENT_WEBHOOK_SECRET=CHANGE_ME_32_bytes_hex
TOPUP_TTL_MINUTES=15

# --- Secret payload encryption (AES-256-GCM key-ring) ---
# "v1:<base64 32B>[,v0:<base64 32B>]" — first key encrypts, all listed decrypt.
# Rotate by prepending a new version; back this up separately from the DB.
PAYLOAD_ENCRYPTION_KEY=v1:CHANGE_ME_base64_of_32_random_bytes

# --- Warming/stock tuning (safe defaults; override only if needed) ---
STOCK_RESERVE_TTL_SECONDS=300
WARMING_HOLD_BUFFER_MINUTES=720
WARMING_DEFAULT_STAGE_MINUTES=1440
# Grace buffer (minutes) added to a line's warranty window for the claim-accept
# check only — a claim filed right on the boundary is not lost to clock skew /
# a slow submit. The displayed expiry is never extended (E10).
WARRANTY_GRACE_MINUTES=60

# --- Monitoring (M5, docs/17 §3) ---
# Sentry DSN for error reporting; empty disables it (no-op, app never depends
# on Sentry being reachable). SENTRY_RELEASE tags events (e.g. the git SHA).
SENTRY_DSN=
SENTRY_RELEASE=

# --- Referral programme (E12, docs/16 §E12+) ---
# REFERRAL_ENABLED=false keeps codes resolving but posts no rewards. Rewards are
# credited to both sides on the referee's first qualifying purchase (paid total,
# after discount, >= REFERRAL_MIN_PURCHASE) and snapshotted on the referral.
# Money amounts are decimal strings; set a side to "0.00" to turn it off.
REFERRAL_ENABLED=true
REFERRAL_REFERRER_REWARD=5.00
REFERRAL_REFEREE_REWARD=5.00
REFERRAL_MIN_PURCHASE=10.00
