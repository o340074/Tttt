# AdVault API — environment
NODE_ENV=development
PORT=3000

# PostgreSQL (docker-compose defaults)
DATABASE_URL=postgresql://advault:advault@localhost:5432/advault?schema=public

# Redis (docker-compose defaults)
REDIS_URL=redis://localhost:6379

# CORS: web dev server origin
CORS_ORIGIN=http://localhost:5173

# Web app base URL (links in emails)
WEB_URL=http://localhost:5173

# JWT (E1 auth). Dev defaults exist in code; ALWAYS override in production.
JWT_ACCESS_SECRET=advault-dev-access-secret-change-me
JWT_REFRESH_SECRET=advault-dev-refresh-secret-change-me
# TTLs in seconds: access 15 min, refresh 30 days
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
